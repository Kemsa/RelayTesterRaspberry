{
  "$schema": "../relay_schema.json",
  "relayBrand": "axicom",
  "relayModel": "v23062-B00029",
  "measures": [
    {
      "name": "resistance de bobine",
      "parameters": {
        "measureType": "coilResistance",
        "coilToMeasure": 1,
        "supplyVoltage_cV": 12e2,
        "successValues": {
          "minResistance_ohm": 90,
          "maxResistance_ohm": 130
        }
      }
    },
    {
      "name": "tension de commutation",
      "parameters": {
        "measureType": "switchingVoltage",
        "coilToMeasure": 1,
        "nContacts": 4,
        "startVoltage_cV": 5e2,
        "stopVoltage_cV": 15e2,
        "voltageStep_cV": 100,
        "successValues": {
          "maxContactOnVoltage_mV": 200,
          "minContactOffVoltage_mV": 2500,
          "maxSwitchingVoltage_cV": 1200
        }
      }
    },
    {
      "name": "tension de relachement",
      "parameters": {
        "measureType": "cutVoltage",
        "coilToMeasure": 1,
        "nContacts": 4,
        "startVoltage_cV": 15e2,
        "stopVoltage_cV": 10,
        "voltageStep_cV": 100,
        "successValues": {
          "maxContactOnVoltage_mV": 100,
          "minContactOffVoltage_mV": 2500,
          "minCutVoltage_cV": 400
        }
      }
    },
    {
      "name": "resistance de contact",
      "parameters": {
        "measureType": "contactResistance",
        "coilToPowerOn": 1,
        "coilToPowerOff": 0,
        "contactDirection": "both",
        "nContacts": 4,
        "supplyVoltage_cV": 12e2,
        "successValues": {
          "maxResistanceClosed_mOhm": 5000,
          "minResistanceOpened_kOhm": 100
        }
      }
    },
    {
      "name": "switching time",
      "parameters": {
        "measureType": "switchingTime",
        "coilToPowerOn": 1,
        "coilToPowerOff": 0,
        "contactDirection": "both",
        "nContacts": 4,
        "contactMaxVoltageSwitch_mV": 100,
        "contactMinVoltageCut_mV": 2500,
        "switchCount": 20,
        "supplyVoltage_cV": 12e2,
        "successValues": {
          "maxSwitchTimeOn_ms": 12,
          "maxSwitchTimeOff_ms": 5,
          "maxCutTimeOn_ms": 8,
          "maxCutTimeOff_ms": 3
        }
      }
    }
  ]
}
