{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "windows-debug",
      "inherits": "default",
      "description": "Native Windows debug build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "C:/Qt/5.15.2/mingw81_64/lib/cmake",
        "CMAKE_C_COMPILER": "C:/Qt/Tools/mingw810_64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/Qt/Tools/mingw810_64/bin/g++.exe",
        "RELAYTESTER_BUILD_UNIT_TESTS": "ON"
      }
    },
    {
      "name": "windows-debug-with-tests",
      "inherits": "windows-debug",
      "description": "Native Windows debug build with unit-test targets",
      "cacheVariables": {
        "RELAYTESTER_BUILD_UNIT_TESTS": "ON"
      }
    },
    {
      "name": "raspi3-crosscompile",
      "inherits": "default",
      "description": "Cross-compile for Raspberry Pi 3 Bookworm",
      "binaryDir": "${sourceDir}/build-rpi",
      "toolchainFile": "${sourceDir}/cmake/toolchains/raspi3-crosscompile.cmake",
      "cacheVariables": {}
    },
    {
      "name": "raspi-native",
      "inherits": "default",
      "description": "Native build directly on Raspberry Pi",
      "binaryDir": "${sourceDir}/build-native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-debug-with-tests",
      "configurePreset": "windows-debug-with-tests",
      "configuration": "Debug"
    },
    {
      "name": "windows-debug-unit-tests",
      "configurePreset": "windows-debug-with-tests",
      "configuration": "Debug",
      "targets": ["relaytester_unit_tests"]
    },
    {
      "name": "raspi3-crosscompile",
      "configurePreset": "raspi3-crosscompile"
    },
    {
      "name": "raspi-native",
      "configurePreset": "raspi-native"
    }
  ],
  "testPresets": [
    {
      "name": "windows-debug-with-tests",
      "configurePreset": "windows-debug-with-tests",
      "filter": {
        "include": {
          "name": "ContactSelectorUnitTest"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-debug-unit-tests",
      "configurePreset": "windows-debug-with-tests",
      "filter": {
        "include": {
          "name": "ContactSelectorUnitTest"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
